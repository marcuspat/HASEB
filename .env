# HASEB Backend Test Environment Configuration
NODE_ENV=test
PORT=3001
API_BASE_URL=http://localhost:3001

# Database Configuration - Test Database (SQLite for testing)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=haseb_test
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_MAX_CONNECTIONS=5
DB_IDLE_TIMEOUT=10000
# Use SQLite for testing to avoid PostgreSQL dependency
DB_TYPE=sqlite
DB_FILE=./test-db/haseb.db

# JWT Configuration - Test Secrets
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# Rate Limiting - Relaxed for testing
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging - Minimal for testing
LOG_LEVEL=error
LOG_FILE_PATH=./test-logs

# Mock API Keys for testing
OPENAI_API_KEY=test-openai-key
ANTHROPIC_API_KEY=test-anthropic-key
E2B_API_KEY=test-e2b-key-for-sandbox-environments

# Benchmark Configuration - Test paths
SWE_BENCH_DATA_PATH=./test-data/swe-bench
GAIA_DATA_PATH=./test-data/gaia
OSWORLD_DATA_PATH=./test-data/osworld
WEBARENA_DATA_PATH=./test-data/webarena

# File Upload Configuration - Test
MAX_FILE_SIZE=1MB
UPLOAD_PATH=./test-uploads

# Security - Test configuration
BCRYPT_ROUNDS=4
SESSION_SECRET=test-session-secret

# Monitoring - Disabled for testing
# SENTRY_DSN=
# PROMETHEUS_PORT=9091

# Cache Configuration - Test
REDIS_URL=redis://localhost:6379/1
CACHE_TTL=60

# Test-specific features
ENABLE_METRICS_COLLECTION=true
ENABLE_REAL_TIME_METRICS=false
ENABLE_DATABASE_LOGGING=false