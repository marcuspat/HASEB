# Test environment configuration (committed: contains only local test defaults, no secrets).
# Loaded by tests/setup.ts via dotenv before the database singleton initializes.
NODE_ENV=test

# Point the global DB singleton at the PostgreSQL test database.
DB_TYPE=postgresql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=haseb_test
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_MAX_CONNECTIONS=5
DB_IDLE_TIMEOUT=10000

# TestDatabase helper reads the *_TEST overrides.
DB_HOST_TEST=127.0.0.1
DB_PORT_TEST=5432
DB_NAME_TEST=haseb_test
DB_USER_TEST=postgres
DB_PASSWORD_TEST=password

JWT_SECRET=test-jwt-secret
SESSION_SECRET=test-session-secret
